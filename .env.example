# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key

# Prisma — pooled connection string (Settings → Database)
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OpenAI — extraction + Annie chat (same key; defaults: gpt-4o-mini)
OPENAI_API_KEY=your-openai-api-key

# Document AI OCR for difficult PDFs — docs/document-ai-ocr.md
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Optional ---

# GEMINI_API_KEY — only if EXTRACTION_PROVIDER=gemini (not needed for default setup)
# GEMINI_API_KEY=your-gemini-api-key
# EXTRACTION_GEMINI_MODEL_ID — optional Gemini model when using gemini extraction (default gemini-3-flash-preview)

# "View on GitHub" links in in-app /docs
# NEXT_PUBLIC_DOCS_GITHUB_BASE=https://github.com/OWNER/REPO/blob/main/docs
# EXTRACTION_PROVIDER — omit for OpenAI (default). gemini|anthropic, model ids, sync confidence, verifier: docs/extraction-architecture.md
# ASSISTANT_MODEL_ID — optional OpenAI model id for Annie (default gpt-4o-mini)
