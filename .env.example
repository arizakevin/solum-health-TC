# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key

# Supabase (server-side only)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key

# Prisma (use pooled connection string from Supabase Dashboard > Settings > Database)
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini AI (primary extraction)
GEMINI_API_KEY=your-gemini-api-key
EXTRACTION_MODEL_ID=gemini-3-flash-preview  # Best quality/cost balance for structured extraction ($0.50/$3.00 per 1M tokens)
ASSISTANT_MODEL_ID=gemini-3-flash-preview

# OpenAI (logprobs confidence fallback) - See docs/extraction-confidence.md
OPENAI_API_KEY=your-openai-api-key
CONFIDENCE_MODEL_ID=gpt-4o-mini  # Used only when Gemini logprobs unavailable

# Document AI OCR GCP (Optional) - $1.50/1000 pages - See docs/document-ai-ocr.md for more details
GOOGLE_CLOUD_PROJECT_ID=gen-lang-client-1234567890
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=document-ai-ocr-1234567890
GOOGLE_APPLICATION_CREDENTIALS=./secrets/Document-AI-OCR-Client.json
