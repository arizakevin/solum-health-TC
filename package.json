{
	"name": "solum-health-tc",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:webpack": "next dev --webpack",
		"dev:turbo": "next dev --turbopack",
		"build": "prisma generate && next build",
		"postinstall": "prisma generate",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"db:push": "prisma db push",
		"db:generate": "prisma generate",
		"db:studio": "prisma studio",
		"reextract:all": "node --env-file=.env --import tsx scripts/reextract-all-cases.ts",
		"bench:extraction": "node --env-file=.env --import tsx scripts/benchmark-extraction-models.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.88.0",
		"@base-ui/react": "^1.3.0",
		"@google-cloud/documentai": "^9.6.0",
		"@google/genai": "latest",
		"@prisma/adapter-pg": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"@react-pdf/renderer": "^4.4.1",
		"@supabase/ssr": "latest",
		"@supabase/supabase-js": "^2.103.0",
		"@tanstack/react-query": "^5.99.0",
		"@vercel/analytics": "^2.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.8.0",
		"mermaid": "^11.14.0",
		"next": "16.2.3",
		"next-themes": "^0.4.6",
		"nextjs-toploader": "^3.9.17",
		"openai": "^6.34.0",
		"pdfjs-dist": "^5.6.205",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.2.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "latest",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"husky": "latest",
		"lint-staged": "latest",
		"prisma": "^7.7.0",
		"tailwindcss": "^4",
		"tsx": "^4.19.0",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{ts,tsx,js,json,css,md}": "biome check --fix --no-errors-on-unmatched"
	}
}
